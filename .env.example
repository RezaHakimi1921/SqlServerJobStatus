# Optional — you can also configure via the web UI on first run.
# Password is NOT stored here — it goes to Windows Credential Manager.
SQL_SERVER=your_server_ip
SQL_DATABASE=msdb
SQL_USER=your_username
SQL_DRIVER=17
SQL_ENCRYPT=no
SQL_TRUST_CERT=yes
SQL_TIMEOUT=10
REFRESH_MINUTES=5
DASH_HOST=127.0.0.1
DASH_PORT=8050
